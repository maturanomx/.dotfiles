[
  { "key": "ctrl+h", "command": "workbench.action.focusLeftGroup",  "when": "!textInputFocus" },
  { "key": "ctrl+j", "command": "workbench.action.focusBelowGroup", "when": "!textInputFocus" },
  { "key": "ctrl+k", "command": "workbench.action.focusAboveGroup", "when": "!textInputFocus" },
  { "key": "ctrl+l", "command": "workbench.action.focusRightGroup", "when": "!textInputFocus" }
]
