tap "mike-engel/jwt-cli"
tap "nikitabobko/tap"
tap "unsecretised/tap"

# --- core ---
brew "curl"
brew "git"
brew "mise"
brew "tmux"
brew "unzip"
brew "zsh"

# --- cli ---
brew "bat"
brew "fd"
brew "ffmpeg-full", link: true
brew "fzf"
brew "harper"
brew "imagemagick-full", link: true
brew "jq"
brew "neovim"
brew "opencode"
brew "ripgrep"
brew "sevenzip"
brew "tree"
brew "wget"
brew "worktrunk"
brew "yazi"
brew "zoxide"

# --- gui & apps ---
cask "firefox@developer-edition"
cask "google-chrome"
cask "keepassxc"
cask "microsoft-teams"
cask "obsidian"
cask "sketchup"
cask "spotify"
cask "wezterm"

# --- dev ---
brew "azure-cli"
brew "colima", restart_service: :changed
brew "docker"
brew "docker-compose"
brew "gawk"
brew "gcc"
brew "gh"
brew "gnu-sed"
brew "grep"
brew "libpq"
brew "mike-engel/jwt-cli/jwt-cli"
brew "poppler"
brew "resvg"
brew "tree-sitter-cli"
cask "claude"
cask "claude-code"
cask "copilot-cli"
cask "cursor"
cask "cursor-cli"
cask "visual-studio-code"


# --- look & feel ---
cask "font-symbols-only-nerd-font"
cask "font-victor-mono"
cask "nikitabobko/tap/aerospace"
cask "raycast"
cask "rustcast"
